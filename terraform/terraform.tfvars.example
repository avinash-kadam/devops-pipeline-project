# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit real values

aws_region       = "us-east-1"
project_name     = "devops-demo"
environment      = "dev"
key_pair_name    = "devops-demo-key"      # must exist in your AWS account
allowed_ssh_cidr = "YOUR_IP/32"           # replace with your actual IP
